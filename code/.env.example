# ═══════════════════════════════════════════════════════
# App Segmentation Pipeline — Configuration
# ═══════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your API keys.
# The pipeline will work without any API keys in --no-llm mode
# (using local bge-small-en-v1.5 embeddings and rule-based naming).
#
# For LLM enrichment and naming, you need at least one provider.
# OpenRouter is recommended — it provides access to many models
# including GLM, GPT-4o-mini, Claude, etc.
# ═══════════════════════════════════════════════════════

# ─── API Keys ───────────────────────────────────────────
# OpenRouter (recommended — supports GLM, GPT, Claude, etc.)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI (alternative — for embeddings + GPT models)
OPENAI_API_KEY=

# ─── Model Configuration ───────────────────────────────
# LLM model for enrichment and naming
# OpenRouter format: openrouter/<model-name>
# Examples:
#   openrouter/google/gemini-2.0-flash-001   — fast, cheap
#   openrouter/anthropic/claude-3.5-sonnet    — high quality
#   openrouter/meta-llama/llama-3.1-70b-instruct — open model
#   openai/gpt-4o-mini                        — via OpenAI directly
LLM_MODEL=openrouter/qwen/qwen3.6-plus

# Fallback LLM model — tried if primary model fails (429 rate limit, errors, etc.)
# If fallback also fails, pipeline uses rule-based naming automatically.
LLM_FALLBACK_MODEL=openrouter/minimax/minimax-m2.7

# Embedding model chain: Primary -> Fallback -> Local (automatic)
# Primary: qwen/qwen3-embedding-8b (1024d, high quality)
EMBEDDING_MODEL=openrouter/qwen/qwen3-embedding-8b
# Fallback: nvidia/llama-nemotron-embed-vl-1b-v2 (2048d, free)
EMBEDDING_FALLBACK_MODEL=openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free
# Set EMBEDDING_MODEL=local to skip API and use local bge-small-en-v1.5 (384d, CPU)

# ─── API Base URLs (auto-configured, usually no need to change) ───
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# ─── Clustering Parameters ─────────────────────────────
# Agglomerative distance threshold (lower = more granular clusters)
DISTANCE_THRESHOLD=0.30

# Noise reassignment cosine similarity threshold
NOISE_REASSIGN_THRESHOLD=0.60

# Maximum cluster size before recursive splitting
MAX_CLUSTER_SIZE=20

# Merge threshold for over-similar clusters (higher = less merging)
MERGE_THRESHOLD=0.96

# ─── HTTP timeouts (seconds) ───────────────────────────
HTTP_TIMEOUT=120
LLM_TIMEOUT=120
EMBEDDING_TIMEOUT=120

# ─── Parallel LLM calls (segment.py + enrich_batch.py) ───
LLM_ENRICHMENT_CONCURRENCY=4
LLM_NAMING_CONCURRENCY=4

# enrich_batch.py only: apps per LLM request (optional)
# ENRICH_BATCH_SIZE=200